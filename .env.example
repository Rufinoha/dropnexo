# DropNexo — copie para .env e preencha (nunca commitar .env)

MODO_PRODUCAO=false
BASE_HOM=http://127.0.0.1:5260
BASE_PROD=https://dropnexo.com.br
PORTA=5260
SESSION_COOKIE_NAME=dropnexo_session
SECRET_KEY=troque-esta-chave

TOKEN_ATIVACAO_HORAS=48

# PostgreSQL DEV
DB_USER_DEV=postgres
DB_PASSWORD_DEV=

# Usuário desenvolvedor (bootstrap_db.py)
DEV_SEED_EMAIL=dev@dropnexo.local
DEV_SEED_SENHA=Dev@DropNexo2026
DEV_SEED_NOME=Desenvolvedor DropNexo
DB_NAME_DEV=bd_dropnexo
DB_HOST_DEV=127.0.0.1
DB_PORT_DEV=5432
DB_SCHEMA_DEV=public

# PostgreSQL PROD
DB_USER_PROD=
DB_PASSWORD_PROD=
DB_NAME_PROD=bd_dropnexo
DB_HOST_PROD=127.0.0.1
DB_PORT_PROD=5432
DB_SCHEMA_PROD=public

# Brevo (e-mail transacional)
BREVO_API_KEY=
BREVO_REMETENTE_EMAIL=notifica@h74.com.br
BREVO_REMETENTE_NOME=Equipe DropNexo

# Contatos (tela em breve)
DROPNEXO_CONTATO_EMAIL=contato@dropnexo.com.br
DROPNEXO_CONTATO_WHATSAPP=5511999999999

# URLs institucionais (e-mails)
URL_POLITICA_PRIVACIDADE=
URL_POLITICA_INTERNA=
URL_DPO=

# Efi Pay (cobranças / boleto) — homologação
EFI_SANDBOX=true
EFI_CLIENT_ID_DEV=
EFI_CLIENT_SECRET_DEV=
EFI_CERT_PATH_DEV=
EFI_CERT_PASSWORD_DEV=
EFI_WEBHOOK_SECRET=

# Efi Pay — produção (quando EFI_SANDBOX=false)
EFI_CLIENT_ID_PROD=
EFI_CLIENT_SECRET_PROD=
EFI_CERT_PATH_PROD=
EFI_CERT_PASSWORD_PROD=

# WhatsApp — reservado
# WHATSAPP_TOKEN=

# Bling ERP (OAuth — app em developer.bling.com.br)
# Redirect URI: {BASE_HOM ou BASE_PROD}/api/integracoes/bling/oauth/callback
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# Mercado Pago — app OAuth da PLATAFORMA (fornecedor conecta a conta dele depois)
# Padrão DropNexo (.env):
#   APPLICATION_ID_DEV / APPLICATION_ID_PROD  → Client ID (OAuth)
#   ACCESS_TOKEN_DEV / ACCESS_TOKEN_PROD        → usado no OAuth como client secret
#   PUBLIC_KEY_DEV / PUBLIC_KEY_PROD            → checkout frontend (futuro)
#   CLIENT_SECRET_DEV / CLIENT_SECRET_PROD      → alternativa explícita ao ACCESS_TOKEN
# Legado: MP_CLIENT_ID / MP_CLIENT_SECRET também são aceitos.
#
# Redirect: {BASE_HOM ou BASE_PROD}/api/integracoes/mercadopago/oauth/callback
# Webhook:  {BASE_HOM ou BASE_PROD}/api/integracoes/mercadopago/webhook
APPLICATION_ID_DEV=
ACCESS_TOKEN_DEV=
APPLICATION_ID_PROD=
ACCESS_TOKEN_PROD=
PUBLIC_KEY_DEV=
PUBLIC_KEY_PROD=
# Opcional: URL fixa de revogação OAuth (POST /oauth/revoke)
# BLING_OAUTH_REVOKE_URL=https://www.bling.com.br/Api/v3/oauth/revoke
